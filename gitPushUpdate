#!/bin/bash
set -e

is_int() { [[ "$1" =~ ^[0-9]+$ ]]; }

# 🔐 Start a clean agent and CAPTURE its socket
eval "$(ssh-agent -s)" >/dev/null

# 🧹 Clear anything in THIS agent
ssh-add -D >/dev/null 2>&1 || true

# ➕ Add your key to THIS agent
ssh-add /Users/morpheous/.ssh/githubceb

# 🚨 FORCE git/ssh to use THIS agent
export SSH_AUTH_SOCK

# Debug (optional, leave for now)
ssh-add -l
ssh -T git@github.com || true

# Init only if needed
[ -d .git ] || git init

git config user.name "ceberous"
git config user.email "cerbus.collin@gmail.com"

LastCommit=$(git rev-list --count HEAD 2>/dev/null || echo 0)

if is_int "$LastCommit"; then
	NextCommitNumber=$((LastCommit+1))
else
	NextCommitNumber=1
fi

if [ -z "$(git status --porcelain)" ]; then
	echo "Nothing to commit"
	exit 0
fi

git add .
git commit -m "$NextCommitNumber"

git remote get-url origin >/dev/null 2>&1 || \
	git remote add origin git@github.com:ceberous/osxSettings.git

git push origin master